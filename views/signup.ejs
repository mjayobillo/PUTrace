<!-- Page: sign up  -->
<%- include('_header') %>
<section class="card narrow">
  <div class="card-head">
    <h2>Create Your Account</h2>
    <p class="muted-subtitle">Start protecting your belongings today</p>
  </div>
  <div class="school-email-note"><i data-lucide="graduation-cap" class="inline-icon"></i> A <strong>@panpacificu.edu.ph</strong> email is required to register.</div>
  <form method="post" action="/signup" id="signupForm">
    <label>Full Name <input name="full_name" required placeholder="Juan dela Cruz" /></label>
    <label>Username
      <input name="username" id="signupUsername" required placeholder="juan123" autocapitalize="none" autocomplete="username" spellcheck="false" />
      <span class="field-hint" id="usernameHint"></span>
    </label>
    <label>School Email
      <div class="input-wrap">
        <input type="text" name="email" id="signupEmail" required placeholder="name" autocapitalize="none" autocomplete="username" spellcheck="false" />
        <span class="input-suffix">@panpacificu.edu.ph</span>
      </div>
      <span class="field-hint" id="emailHint"></span>
    </label>
    <p class="field-note" style="margin-top:-0.35rem;">After signing up, you’ll verify this email before you can log in. Check spam/junk if you don’t see it.</p>
    <label>Password <small style="font-weight:400;color:#aaa;">(min 8 characters)</small>
      <div class="password-wrap">
        <input type="password" name="password" id="signupPassword" required minlength="8" placeholder="Create a strong password" />
        <span class="pw-toggle" onclick="togglePassword('signupPassword', this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();togglePassword('signupPassword', this)}" title="Show password" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
      </div>
    </label>
    <label>Confirm password
      <div class="password-wrap">
        <input type="password" name="confirm_password" id="signupConfirmPassword" required minlength="8" placeholder="Re-enter your password" />
        <span class="pw-toggle" onclick="togglePassword('signupConfirmPassword', this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();togglePassword('signupConfirmPassword', this)}" title="Show password" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
      </div>
    </label>
    <button type="submit">Create Account</button>
  </form>
  <p class="center-text form-link-sub">Already have an account? <a href="/login">Sign in</a></p>
</section>

<script>
  (function () {
    var usernameInput = document.getElementById('signupUsername');
    var emailInput = document.getElementById('signupEmail');
    var usernameHint = document.getElementById('usernameHint');
    var emailHint = document.getElementById('emailHint');
    var usernameTimer = null;
    var emailTimer = null;

    function setHint(el, message, tone) {
      if (!el) return;
      el.textContent = message || '';
      el.className = 'field-hint' + (tone ? ' is-' + tone : '');
    }

    function debounce(fn, delay, store) {
      if (store.timer) window.clearTimeout(store.timer);
      store.timer = window.setTimeout(fn, delay);
    }

    function checkUsername() {
      var value = (usernameInput && usernameInput.value || '').trim();
      if (!value) return setHint(usernameHint, '', '');
      setHint(usernameHint, 'Checking availability...', 'muted');
      fetch('/api/check-username?username=' + encodeURIComponent(value), { headers: { Accept: 'application/json' }, cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data) return;
          if (data.available) return setHint(usernameHint, 'Username is available', 'good');
          if (data.reason === 'invalid') return setHint(usernameHint, 'Use 3–30 lowercase letters, numbers, dots, or underscores', 'warn');
          setHint(usernameHint, 'Username is already taken', 'bad');
        })
        .catch(function () {});
    }

    function checkEmail() {
      var value = (emailInput && emailInput.value || '').trim();
      if (!value) return setHint(emailHint, '', '');
      var fullEmail = value.indexOf('@') === -1 ? (value + '@panpacificu.edu.ph') : value;
      setHint(emailHint, 'Checking availability...', 'muted');
      fetch('/api/check-email?email=' + encodeURIComponent(fullEmail), { headers: { Accept: 'application/json' }, cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data) return;
          if (data.available) return setHint(emailHint, 'Email is available', 'good');
          if (data.reason === 'domain') return setHint(emailHint, 'Use your @panpacificu.edu.ph email', 'warn');
          if (data.reason === 'invalid') return setHint(emailHint, 'Enter a valid email', 'warn');
          setHint(emailHint, 'Email is already registered', 'bad');
        })
        .catch(function () {});
    }

    if (usernameInput) {
      usernameInput.addEventListener('input', function () {
        debounce(checkUsername, 350, { get timer() { return usernameTimer; }, set timer(v) { usernameTimer = v; } });
      });
      usernameInput.addEventListener('blur', checkUsername);
    }

    if (emailInput) {
      emailInput.addEventListener('input', function () {
        debounce(checkEmail, 350, { get timer() { return emailTimer; }, set timer(v) { emailTimer = v; } });
      });
      emailInput.addEventListener('blur', checkEmail);
    }
  })();
</script>

<%- include('_footer') %>
