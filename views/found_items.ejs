<%- include('_header') %>

<div style="text-align:center;margin-bottom:1.5rem;">
  <h2 style="font-size:1.8rem;"><i data-lucide="package-open" class="inline-icon"></i> Found Items Board</h2>
  <p style="color:#888;max-width:550px;margin:0.5rem auto 0;">Found something on campus? Post it here so the owner can claim it. Looking for your lost item? Browse below!</p>
</div>

<!-- Post a Found Item -->
<section class="card">
  <details>
    <summary class="button btn-outline" style="width:100%;text-align:center;list-style:none;cursor:pointer;">
      ➕ I found an item — post it here
    </summary>
    <form method="post" action="/found-items" enctype="multipart/form-data" style="margin-top:1.2rem;">
      <div class="form-grid-2">
        <label>Your name <input name="finder_name" required placeholder="Your full name" value="<%= currentUser ? currentUser.full_name : '' %>" <%= currentUser ? 'readonly' : '' %> /></label>
        <label>Your email <input type="email" name="finder_email" required placeholder="you@email.com" value="<%= currentUser ? currentUser.email : '' %>" <%= currentUser ? 'readonly' : '' %> /></label>
      </div>
      <div class="form-grid-2">
        <label>Item name <input name="item_name" required placeholder="e.g. Black Hydro Flask" /></label>
        <label>Category
          <select name="category">
            <% categories.forEach((cat) => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <label>Where did you find it? <input name="location_found" required placeholder="e.g. Library 2nd floor, Room 301" /></label>
      <label>Description <textarea name="item_description" rows="3" maxlength="1000" placeholder="Describe the item — color, brand, distinguishing marks..."></textarea></label>
      <label>Photo (optional) <input type="file" name="image" accept="image/*" /></label>
      <button type="submit" class="btn-success">Post Found Item</button>
    </form>
  </details>
</section>

<!-- Search & Filter -->
<section class="card">
  <form method="get" action="/found-items" class="search-filters">
    <div class="board-filter-row">
      <label class="board-filter-search">
        Search
        <input type="text" name="search" value="<%= search %>" placeholder="Search found items..." />
      </label>
      <label class="board-filter-category">
        Category
        <select name="category">
          <option value="">All</option>
          <% categories.forEach((cat) => { %>
            <option value="<%= cat %>" <%= filterCategory === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </label>
      <button type="submit" class="btn-sm board-filter-btn">Filter</button>
      <% if (search || filterCategory) { %>
        <a href="/found-items" class="button btn-sm btn-outline board-filter-btn">Clear</a>
      <% } %>
    </div>
  </form>
</section>

<!-- Results -->
<% if (!posts || posts.length === 0) { %>
  <section class="card center-text" style="padding:3rem;">
    <div style="font-size:3rem;margin-bottom:0.5rem;"><i data-lucide="inbox" style="width:3rem;height:3rem;color:#bbb;"></i></div>
    <% if (search || filterCategory) { %>
      <h3>No items match your search</h3>
      <p style="color:#888;">Try different keywords or <a href="/found-items">clear filters</a></p>
    <% } else { %>
      <h3>No found items posted yet</h3>
      <p style="color:#888;">Found something on campus? Be the first to post it!</p>
    <% } %>
  </section>
<% } else { %>
  <p style="color:#888;margin-bottom:1rem;font-size:0.9rem;"><%= posts.filter(p => p.status === 'unclaimed').length %> item<%= posts.filter(p => p.status === 'unclaimed').length !== 1 ? 's' : '' %> unclaimed</p>

  <div class="lost-grid">
    <% posts.forEach((post) => { %>
      <article class="lost-card<%= post.status === 'claimed' ? ' lost-card-claimed' : '' %>">
        <div class="lost-card-header">
          <div>
            <h3><%= post.item_name %></h3>
            <% if (post.category && post.category !== 'Other') { %>
              <span class="badge badge-category"><%= post.category %></span>
            <% } %>
          </div>
          <% if (post.status === 'claimed') { %>
            <span class="badge badge-open">Claim Pending</span>
          <% } else { %>
            <span class="badge badge-active">Found</span>
          <% } %>
        </div>
        <% if (post.image_url) { %>
          <div class="item-image-wrap">
            <img src="<%= post.image_url %>" alt="<%= post.item_name %>" class="item-image" style="cursor:pointer;" data-img="<%= post.image_url %>" data-label="<%= post.item_name %>" onclick="showBoardImg(this.dataset.img, this.dataset.label)" />
          </div>
        <% } else { %>
          <div class="item-image-wrap item-image-placeholder">
            <div class="item-image-placeholder-inner">
              <i data-lucide="image-off" style="width:2rem;height:2rem;color:#3a56e4;"></i>
              <strong>No photo provided</strong>
              <span>Use the description and location to verify the item.</span>
            </div>
          </div>
        <% } %>
        <p class="lost-card-desc"><%= post.item_description || 'No description provided' %></p>
        <div class="lost-card-meta">
          <span>Found by <strong><%= post.finder_name.split(' ')[0] %></strong></span>
          <% if (post.location_found) { %>
            <span>&#183; <%= post.location_found %></span>
          <% } %>
          <span>&#183; <%= new Date(post.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %>, <%= new Date(post.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %></span>
        </div>
        <% if (post.status === 'claimed') { %>
          <% const isInvolved = currentUser && (post.finder_user_id === currentUser.id || post.claimer_user_id === currentUser.id); %>
          <% if (isInvolved) { %>
            <a href="/found-messages/<%= post.id %>" class="button btn-sm btn-outline" style="width:100%;margin-top:0.8rem;">View Chat</a>
          <% } else { %>
            <p style="margin-top:0.8rem;font-size:0.85rem;color:#aaa;text-align:center;">This item currently has a pending claim.</p>
          <% } %>
        <% } else if (currentUser && post.finder_user_id === currentUser.id) { %>
          <div style="display:flex;gap:0.5rem;margin-top:0.8rem;">
            <p style="flex:1;font-size:0.85rem;color:#aaa;margin:0;line-height:1.4;">This is your post.</p>
            <form method="post" action="/found-items/<%= post.id %>/delete" class="delete-confirm-form" data-delete-label="<%= post.item_name %>" data-delete-message="Remove this post from the board?" style="flex-shrink:0;">
              <button type="submit" class="btn-sm btn-danger">Remove</button>
            </form>
          </div>
        <% } else if (currentUser) { %>
          <button type="button" class="btn-sm btn-success" style="width:100%;margin-top:0.8rem;" onclick="showClaimModal('<%= post.item_name.replace(/'/g, "\\'") %>', '<%= post.finder_name %>', '<%= (post.location_found || '').replace(/'/g, "\\'") %>', <%= post.id %>)">This is mine &mdash; Claim it</button>
        <% } else { %>
          <p style="margin-top:0.8rem;font-size:0.85rem;color:#888;text-align:center;">
            <a href="/login">Login</a> to claim this item
          </p>
        <% } %>
      </article>
    <% }) %>
  </div>
<% } %>

<!-- Claim Modal Overlay -->
<div id="claimModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <button class="modal-close" onclick="closeClaimModal()">&times;</button>
    <div style="text-align:center;margin-bottom:1.2rem;">
      <div><i data-lucide="party-popper" style="width:2.5rem;height:2.5rem;color:#3a56e4;"></i></div>
      <h2 style="margin-top:0.5rem;" id="modalTitle">Item Claimed!</h2>
    </div>
    <p style="color:#555;text-align:center;margin-bottom:1.5rem;">You'll be able to chat with the finder after claiming.</p>
    <div class="modal-info">
      <div class="modal-info-row">
        <span class="modal-label"><i data-lucide="user" class="inline-icon"></i> Finder</span>
        <span id="modalFinderName" class="modal-value"></span>
      </div>
      <div class="modal-info-row" id="modalLocationRow" style="display:none;">
        <span class="modal-label"><i data-lucide="map-pin" class="inline-icon"></i> Found at</span>
        <span id="modalLocation" class="modal-value"></span>
      </div>
    </div>
    <form id="claimForm" method="post" action="" style="margin-top:1.5rem;">
      <button type="submit" class="btn-success" style="width:100%;">Confirm Claim</button>
    </form>
    <button type="button" onclick="closeClaimModal()" class="button btn-outline" style="width:100%;margin-top:0.5rem;">Cancel</button>
  </div>
</div>

<div id="boardImgModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:999;align-items:center;justify-content:center;" onclick="this.style.display='none'">
  <div style="max-width:90vw;max-height:90vh;text-align:center;">
    <img id="boardImgEl" src="" alt="" style="max-width:100%;max-height:80vh;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);" />
    <p id="boardImgLabel" style="color:#fff;margin-top:0.75rem;font-size:0.95rem;"></p>
  </div>
</div>

<div id="delete-confirm-modal" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="delete-confirm-title">
  <div class="modal-box modal-box-error">
    <button type="button" class="modal-close" id="delete-confirm-close" aria-label="Close delete confirmation">&times;</button>
    <div style="text-align:center;margin-bottom:0.8rem;"><i data-lucide="trash-2" style="width:2.2rem;height:2.2rem;color:#e74c3c;"></i></div>
    <h3 id="delete-confirm-title" class="error-title">Remove post?</h3>
    <p id="delete-confirm-message" class="error-message">This action cannot be undone.</p>
    <div class="success-actions">
      <button type="button" class="btn-sm btn-outline" id="delete-confirm-cancel">Cancel</button>
      <button type="button" class="btn-sm btn-danger" id="delete-confirm-submit">Remove</button>
    </div>
  </div>
</div>

<script>
  function showBoardImg(src, label) {
    document.getElementById('boardImgEl').src = src;
    document.getElementById('boardImgEl').alt = label || 'Item image';
    document.getElementById('boardImgLabel').textContent = label || '';
    document.getElementById('boardImgModal').style.display = 'flex';
  }

  function showClaimModal(itemName, finderName, location, postId) {
    document.getElementById('modalTitle').textContent = 'Claim "' + itemName + '"';
    document.getElementById('modalFinderName').textContent = finderName;
    document.getElementById('claimForm').action = '/found-items/' + postId + '/claim';
    if (location) {
      document.getElementById('modalLocation').textContent = location;
      document.getElementById('modalLocationRow').style.display = 'flex';
    } else {
      document.getElementById('modalLocationRow').style.display = 'none';
    }
    document.getElementById('claimModal').style.display = 'flex';
  }
  function closeClaimModal() {
    document.getElementById('claimModal').style.display = 'none';
  }
  document.getElementById('claimModal').addEventListener('click', function(e) {
    if (e.target === this) closeClaimModal();
  });
  (function () {
    var modal = document.getElementById('delete-confirm-modal');
    var titleEl = document.getElementById('delete-confirm-title');
    var messageEl = document.getElementById('delete-confirm-message');
    var closeBtn = document.getElementById('delete-confirm-close');
    var cancelBtn = document.getElementById('delete-confirm-cancel');
    var submitBtn = document.getElementById('delete-confirm-submit');
    var pendingForm = null;

    if (!modal || !titleEl || !messageEl || !submitBtn) return;

    function closeDeleteModal() {
      modal.style.display = 'none';
      pendingForm = null;
    }

    document.querySelectorAll('.delete-confirm-form').forEach(function (form) {
      form.addEventListener('submit', function (event) {
        event.preventDefault();
        pendingForm = form;
        var label = form.dataset.deleteLabel || 'this post';
        var message = form.dataset.deleteMessage || 'Remove this post?';
        titleEl.textContent = 'Remove "' + label + '"?';
        messageEl.textContent = message;
        modal.style.display = 'flex';
        submitBtn.focus();
      });
    });

    submitBtn.addEventListener('click', function () {
      if (!pendingForm) return;
      modal.style.display = 'none';
      pendingForm.submit();
    });
    if (closeBtn) closeBtn.addEventListener('click', closeDeleteModal);
    if (cancelBtn) cancelBtn.addEventListener('click', closeDeleteModal);
    modal.addEventListener('click', function (event) {
      if (event.target === modal) closeDeleteModal();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeClaimModal();
        closeDeleteModal();
        var imgModal = document.getElementById('boardImgModal');
        if (imgModal) imgModal.style.display = 'none';
      }
    });
  })();
</script>

<%- include('_footer') %>
