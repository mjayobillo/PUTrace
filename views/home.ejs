<%- include('_header') %>

<section class="hero">
  <h2>Never Lose What Matters</h2>
  <p>Tag your belongings with unique QR codes. When someone finds your lost item, they can instantly reach you.</p>
  <div class="hero-actions">
    <% if (currentUser) { %>
      <a class="button" href="/dashboard">Go to Dashboard</a>
      <a class="button hero-secondary-btn" href="/lost">Lost Board</a>
    <% } else { %>
      <a class="button" href="/signup">Sign Up Free</a>
      <a class="button hero-secondary-btn" href="/login">Login</a>
    <% } %>
  </div>
</section>

<!-- ── Proof of Experience ── -->
<section class="proof-section">
  <div class="proof-header">
    <span class="proof-label">Real scenario</span>
    <h2>What happens when someone finds your item</h2>
    <p>No app to download. No account needed to report a find. Just a scan.</p>
  </div>
  <div class="proof-flow">

    <div class="proof-step">
      <div class="proof-step-num">1</div>
      <div class="proof-screen">
        <div class="proof-chrome"><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-url">putrace.onrender.com/found/a3f…</span></div>
        <div class="proof-body proof-body-center">
          <div class="proof-qr-mock">
            <svg viewBox="0 0 40 40" width="64" height="64" fill="none"><rect x="2" y="2" width="14" height="14" rx="2" fill="#1a2340"/><rect x="5" y="5" width="8" height="8" rx="1" fill="#fff"/><rect x="7" y="7" width="4" height="4" rx="0.5" fill="#1a2340"/><rect x="24" y="2" width="14" height="14" rx="2" fill="#1a2340"/><rect x="27" y="5" width="8" height="8" rx="1" fill="#fff"/><rect x="29" y="7" width="4" height="4" rx="0.5" fill="#1a2340"/><rect x="2" y="24" width="14" height="14" rx="2" fill="#1a2340"/><rect x="5" y="27" width="8" height="8" rx="1" fill="#fff"/><rect x="7" y="29" width="4" height="4" rx="0.5" fill="#1a2340"/><rect x="24" y="24" width="4" height="4" fill="#1a2340"/><rect x="30" y="24" width="4" height="4" fill="#1a2340"/><rect x="24" y="30" width="4" height="4" fill="#1a2340"/><rect x="30" y="30" width="4" height="4" fill="#1a2340"/><rect x="18" y="2" width="4" height="4" fill="#1a2340"/><rect x="18" y="8" width="4" height="4" fill="#1a2340"/><rect x="2" y="18" width="4" height="4" fill="#1a2340"/><rect x="8" y="18" width="4" height="4" fill="#1a2340"/></svg>
          </div>
          <div class="proof-sticker-label">Scan to return this item</div>
        </div>
      </div>
      <p class="proof-step-label">Finder scans the QR sticker</p>
    </div>

    <div class="proof-arrow"><i data-lucide="chevron-right"></i></div>

    <div class="proof-step">
      <div class="proof-step-num">2</div>
      <div class="proof-screen">
        <div class="proof-chrome"><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-url">putrace.onrender.com/found/a3f…</span></div>
        <div class="proof-body">
          <div class="proof-item-name">Blue Water Bottle</div>
          <div class="proof-meta-row"><span class="proof-badge-cat">Bottles</span></div>
          <div class="proof-owner-row">
            <div class="proof-avatar">M</div>
            <div>
              <div class="proof-owner-name">Marc Jay Obillo</div>
              <div class="proof-owner-sub">Registered owner</div>
            </div>
          </div>
          <div class="proof-cta-mock">Report Found Item</div>
        </div>
      </div>
      <p class="proof-step-label">Owner's contact page opens instantly</p>
    </div>

    <div class="proof-arrow"><i data-lucide="chevron-right"></i></div>

    <div class="proof-step">
      <div class="proof-step-num">3</div>
      <div class="proof-screen">
        <div class="proof-chrome"><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-url">Submit a finder report</span></div>
        <div class="proof-body">
          <div class="proof-field-label">Your name</div>
          <div class="proof-fake-input">Juan dela Cruz</div>
          <div class="proof-field-label">Where did you find it?</div>
          <div class="proof-fake-input proof-fake-textarea">Library entrance, 2nd floor. Left it by the charging station.</div>
          <div class="proof-submit-mock">Send Report</div>
        </div>
      </div>
      <p class="proof-step-label">Finder submits a report</p>
    </div>

    <div class="proof-arrow"><i data-lucide="chevron-right"></i></div>

    <div class="proof-step">
      <div class="proof-step-num">4</div>
      <div class="proof-screen proof-screen-success">
        <div class="proof-chrome proof-chrome-dark"><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-dot"></span><span class="proof-url proof-url-light">Dashboard — PUTrace</span></div>
        <div class="proof-body">
          <div class="proof-notify-card">
            <div class="proof-notify-pulse"></div>
            <div class="proof-notify-content">
              <div class="proof-notify-title">New finder report</div>
              <div class="proof-notify-item">Blue Water Bottle &middot; <span class="proof-time">just now</span></div>
              <div class="proof-notify-msg">"Library entrance, 2nd floor. Left it by the charging station."</div>
            </div>
          </div>
          <div class="proof-open-chat-mock">Open Chat</div>
        </div>
      </div>
      <p class="proof-step-label">Owner is notified &amp; can reply</p>
    </div>

  </div>
</section>

<div class="feature-grid">
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="qr-code"></i></div>
    <h3>Generate QR Codes</h3>
    <p>Create unique QR codes for each of your items. Print them, stick them on, and you're protected.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="scan-search"></i></div>
    <h3>Instant Discovery</h3>
    <p>When someone finds your item, one scan reveals how to reach you — no app needed.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="message-circle"></i></div>
    <h3>Direct Messaging</h3>
    <p>Chat directly with the finder through a private message thread — coordinate the return of your item in real time.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="graduation-cap"></i></div>
    <h3>Built for Campus</h3>
    <p>Designed for students who lose things around campus — laptops, bottles, IDs, and more.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="clipboard-list"></i></div>
    <h3>Lost Board</h3>
    <p>Mark your item as lost and post it to the campus board so other students can report sightings.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon"><i data-lucide="package-open"></i></div>
    <h3>Found Board</h3>
    <p>Found something that isn't yours? Post it on the Found Board so the owner can claim it.</p>
  </div>
</div>

<%- include('_footer') %>
