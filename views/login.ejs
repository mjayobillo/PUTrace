<!-- Page: log in  -->
<%- include('_header') %>
<section class="card narrow">
  <% const isLoginConfirmed = typeof loginConfirmed !== 'undefined' && !!loginConfirmed; %>
  <% if (isLoginConfirmed) { %>
    <div class="flash success">Confirmed! Redirecting...</div>
    <script>
      setTimeout(function () {
        window.location.href = "<%= (typeof redirectTo !== 'undefined' && redirectTo) ? redirectTo : '/dashboard' %>";
      }, 1000);
    </script>
  <% } %>
  <div class="card-head">
    <h2>Welcome Back</h2>
    <p class="muted-subtitle">Sign in to manage your items</p>
  </div>
  <button onclick="openGoogleAuth()" class="button btn-outline btn-block" style="display:flex; align-items:center; justify-content:center; gap:0.5rem; margin-bottom: 1.5rem; border-color:#cbd5e1; color:#334155; font-weight:600; cursor:pointer;">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
    Continue with Google
  </button>
  <script>
    function openGoogleAuth() {
      const width = 500;
      const height = 600;
      const left = window.screenX + (window.outerWidth - width) / 2;
      const top = window.screenY + (window.outerHeight - height) / 2;
      window.open('/auth/google', 'google-login', `width=${width},height=${height},left=${left},top=${top},toolbar=0,scrollbars=1,status=1,resizable=1,location=1,menuBar=0`);
    }
    
    // Listen for the popup telling us it finished successfully
    window.addEventListener('message', function(event) {
      if (event.origin !== window.location.origin) return;
      if (event.data === 'google-auth-success') {
        window.location.href = '/dashboard';
      }
    });
  </script>
  <div style="display:flex; align-items:center; text-align:center; padding-bottom:1rem;">
    <div style="flex:1; border-top:1px solid #e2e8f0;"></div>
    <div style="padding:0 0.75rem; color:#94a3b8; font-size:0.85rem; font-weight:600; text-transform:uppercase;">or sign in manually</div>
    <div style="flex:1; border-top:1px solid #e2e8f0;"></div>
  </div>
  <form method="post" action="/login">
    <input type="hidden" name="redirectTo" value="<%= (typeof redirectTo !== 'undefined' && redirectTo) ? redirectTo : '' %>" />
    <label>Username or School Email
      <div class="input-wrap">
        <input type="text" name="identifier" id="loginIdentifier" required placeholder="juan123 or name@panpacificu.edu.ph" autocapitalize="none" autocomplete="username" spellcheck="false" />
      </div>
    </label>
    <label>Password
      <div class="password-wrap">
        <input type="password" name="password" id="loginPassword" required placeholder="Enter your password" />
        <span class="pw-toggle" onclick="togglePassword('loginPassword', this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();togglePassword('loginPassword', this)}" title="Show password" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
      </div>
    </label>
    <button type="submit" id="login-submit-btn">Sign In</button>
  </form>
  <div style="margin-top:1.25rem; text-align:center;">
    <a href="javascript:void(0)" id="resendVerifyBtn" style="color:#3a56e4; font-weight:500; font-size:0.95rem; cursor:pointer; text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Resend verification email</a>
    <div id="resendVerifyHint" class="field-hint" style="margin-top:0.25rem;"></div>
  </div>
  <p class="center-text form-link" style="margin-top:0.75rem;"><a href="/forgot-password">Forgot password?</a></p>
  <p class="center-text form-link-sub">Don't have an account? <a href="/signup">Sign up</a></p>
</section>

<script>
  (function () {
    var btn = document.getElementById('resendVerifyBtn');
    var hint = document.getElementById('resendVerifyHint');
    var input = document.getElementById('loginIdentifier');

    function setHint(message, tone) {
      if (!hint) return;
      hint.textContent = message || '';
      hint.className = 'field-hint' + (tone ? ' is-' + tone : '');
    }

    function setCooldown(seconds) {
      if (!btn) return;
      btn.disabled = true;
      var remaining = seconds;
      btn.textContent = 'Resend in ' + remaining + 's';
      var timer = window.setInterval(function () {
        remaining -= 1;
        if (remaining <= 0) {
          window.clearInterval(timer);
          btn.disabled = false;
          btn.textContent = 'Resend verification email';
          return;
        }
        btn.textContent = 'Resend in ' + remaining + 's';
      }, 1000);
    }

    if (btn) {
      btn.addEventListener('click', function () {
        var value = (input && input.value || '').trim();
        if (!value) {
          setHint('Enter your username or school email first.', 'warn');
          return;
        }
        setHint('Sending verification email...', 'muted');
        fetch('/resend-verification', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: 'identifier=' + encodeURIComponent(value)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data) return;
            setHint(data.message || 'Done.', data.ok === false ? 'bad' : 'good');
            if (data.cooldown) setCooldown(data.cooldown);
            else if (data.ok !== false) setCooldown(60);
          })
          .catch(function () {
            setHint('Something went wrong. Please try again.', 'bad');
          });
      });
    }
  })();
</script>
<%- include('_footer') %>
