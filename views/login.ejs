<!-- Page: log in  -->
<%- include('_header') %>
<section class="card narrow">
  <% const isLoginConfirmed = typeof loginConfirmed !== 'undefined' && !!loginConfirmed; %>
  <% if (isLoginConfirmed) { %>
    <div class="flash success">Confirmed! Redirecting...</div>
    <script>
      setTimeout(function () {
        window.location.href = "<%= (typeof redirectTo !== 'undefined' && redirectTo) ? redirectTo : '/dashboard' %>";
      }, 1000);
    </script>
  <% } %>
  <div class="card-head">
    <h2>Welcome Back</h2>
    <p class="muted-subtitle">Sign in to manage your items</p>
  </div>
  <form method="post" action="/login">
    <input type="hidden" name="redirectTo" value="<%= (typeof redirectTo !== 'undefined' && redirectTo) ? redirectTo : '' %>" />
    <label>Username or School Email
      <div class="input-wrap">
        <input type="text" name="identifier" id="loginIdentifier" required placeholder="juan123 or name@panpacificu.edu.ph" autocapitalize="none" autocomplete="username" spellcheck="false" />
      </div>
    </label>
    <label>Password
      <div class="password-wrap">
        <input type="password" name="password" id="loginPassword" required placeholder="Enter your password" />
        <span class="pw-toggle" onclick="togglePassword('loginPassword', this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();togglePassword('loginPassword', this)}" title="Show password" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
      </div>
    </label>
    <button type="submit" id="login-submit-btn">Sign In</button>
  </form>
  <div style="margin-top:0.75rem;">
    <button type="button" class="button btn-outline btn-sm" id="resendVerifyBtn">Resend verification email</button>
    <span class="field-hint" id="resendVerifyHint"></span>
  </div>
  <p class="center-text form-link"><a href="/forgot-password">Forgot password?</a></p>
  <p class="center-text form-link-sub">Don't have an account? <a href="/signup">Sign up</a></p>
</section>

<script>
  (function () {
    var btn = document.getElementById('resendVerifyBtn');
    var hint = document.getElementById('resendVerifyHint');
    var input = document.getElementById('loginIdentifier');

    function setHint(message, tone) {
      if (!hint) return;
      hint.textContent = message || '';
      hint.className = 'field-hint' + (tone ? ' is-' + tone : '');
    }

    function setCooldown(seconds) {
      if (!btn) return;
      btn.disabled = true;
      var remaining = seconds;
      btn.textContent = 'Resend in ' + remaining + 's';
      var timer = window.setInterval(function () {
        remaining -= 1;
        if (remaining <= 0) {
          window.clearInterval(timer);
          btn.disabled = false;
          btn.textContent = 'Resend verification email';
          return;
        }
        btn.textContent = 'Resend in ' + remaining + 's';
      }, 1000);
    }

    if (btn) {
      btn.addEventListener('click', function () {
        var value = (input && input.value || '').trim();
        if (!value) {
          setHint('Enter your username or school email first.', 'warn');
          return;
        }
        setHint('Sending verification email...', 'muted');
        fetch('/resend-verification', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: 'identifier=' + encodeURIComponent(value)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data) return;
            setHint(data.message || 'Done.', data.ok === false ? 'bad' : 'good');
            if (data.cooldown) setCooldown(data.cooldown);
            else if (data.ok !== false) setCooldown(60);
          })
          .catch(function () {
            setHint('Something went wrong. Please try again.', 'bad');
          });
      });
    }
  })();
</script>
<%- include('_footer') %>
