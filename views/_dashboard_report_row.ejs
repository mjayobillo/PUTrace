<div class="report-card">
  <div class="report-card-header">
    <strong class="report-item-name"><%= r.item_name %></strong>
    <% if (r.status === 'open') { %>
      <span class="badge badge-open">Open</span>
    <% } else { %>
      <span class="badge badge-resolved">Resolved</span>
    <% } %>
  </div>
  <div class="report-card-body">
    <p class="report-finder"><span class="report-label">Finder:</span> <%= r.finder_name %> &mdash; <small class="muted"><%= r.finder_email %></small></p>
    <p class="report-message"><span class="report-label">Message:</span> <%= r.message %>
      <% if (r.location_hint) { %><br/><small class="muted"><%= r.location_hint %></small><% } %>
    </p>
  </div>
  <div class="report-card-actions">
    <a href="/messages/<%= r.id %>" class="button btn-sm btn-outline">Open Chat</a>
    <% if (r.status === 'open') { %>
      <form method="post" action="/report/<%= r.id %>/resolve" class="inline-form">
        <button type="submit" class="button btn-sm btn-success">Resolve</button>
      </form>
    <% } %>
  </div>
</div>
