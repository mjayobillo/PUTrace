<!-- View partial: generic confirm modal  -->
<div id="confirm-modal" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
  <div class="modal-box">
    <button type="button" class="modal-close" id="confirm-close" aria-label="Close confirmation">&times;</button>
    <div class="modal-icon-wrap"><i data-lucide="log-out" class="modal-icon-error"></i></div>
    <h3 id="confirm-title" class="success-title">Are you sure?</h3>
    <p id="confirm-message" class="success-message">Please confirm this action.</p>
    <div class="success-actions">
      <button type="button" class="btn-sm btn-outline" id="confirm-cancel">Cancel</button>
      <button type="button" class="btn-sm btn-danger" id="confirm-submit">Confirm</button>
    </div>
  </div>
</div>
