<%- include('_header') %>
<section class="card narrow">
  <div class="center-text" style="margin-bottom:1.5rem;">
    <h2>Forgot Password</h2>
    <p style="color:#888;font-size:0.9rem;">Enter your school email and we'll send a reset link.</p>
  </div>
  <form method="post" action="/forgot-password">
    <label>School email
      <div style="display:flex;align-items:center;border:1px solid #d9e0ea;border-radius:10px;overflow:hidden;background:#fff;">
        <input type="text" name="email" required placeholder="name" autocapitalize="none" autocomplete="username" spellcheck="false" style="border:0;border-radius:0;box-shadow:none;flex:1;" />
        <span style="padding:0 0.9rem;color:#667085;background:#f8f9fc;border-left:1px solid #e5e7eb;white-space:nowrap;">@panpacificu.edu.ph</span>
      </div>
    </label>
    <button type="submit">Send Reset Link</button>
  </form>
  <p class="center-text" style="margin-top:1rem;font-size:0.9rem;color:#888;"><a href="/login">Back to login</a></p>
</section>
<%- include('_footer') %>
