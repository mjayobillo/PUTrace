<%- include('_header') %>
<section class="card narrow">
  <div class="card-head">
    <h2>Forgot Password</h2>
  <p class="muted-subtitle">Enter your school email and we'll send a reset link. Check spam/junk if you don’t see it.</p>
  </div>
  <form method="post" action="/forgot-password">
    <label>School email
      <div class="input-wrap">
        <input type="text" name="email" required placeholder="name" autocapitalize="none" autocomplete="username" spellcheck="false" />
        <span class="input-suffix">@panpacificu.edu.ph</span>
      </div>
    </label>
    <button type="submit">Send Reset Link</button>
  </form>
  <p class="center-text form-link-sub"><a href="/login">Back to login</a></p>
</section>
<%- include('_footer') %>
