<%- include('_header') %>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
  <i data-lucide="shield" style="width:1.6rem;height:1.6rem;color:#3a56e4;"></i>
  <h2 style="font-size:1.6rem;margin:0;">Admin Panel</h2>
</div>

<!-- Stats bar -->
<div class="stats-bar" style="margin-bottom:1.5rem;">
  <div class="stat-card">
    <div class="stat-number"><%= users.length %></div>
    <div class="stat-label">Users</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= users.filter(u => u.is_banned).length %></div>
    <div class="stat-label">Banned</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= foundPosts.length %></div>
    <div class="stat-label">Found Posts</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= reports.length %></div>
    <div class="stat-label">Reports</div>
  </div>
</div>

<!-- Users -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="users" class="inline-icon"></i> Users</h3>
  <% if (users.length === 0) { %>
    <p class="muted">No users yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Joined</th>
            <th>Role</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((u) => { %>
            <tr class="<%= u.is_banned ? 'admin-row-banned' : '' %>">
              <td><%= u.full_name %></td>
              <td style="font-size:0.85rem;color:#666;"><%= u.email %></td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;"><%= new Date(u.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric', year: 'numeric' }) %></td>
              <td>
                <% if (u.is_admin) { %>
                  <span class="badge badge-active">Admin</span>
                <% } else if (u.is_banned) { %>
                  <span class="badge badge-resolved" style="background:#fee2e2;color:#b91c1c;border-color:#fca5a5;">Banned</span>
                <% } else { %>
                  <span class="badge badge-none">User</span>
                <% } %>
              </td>
              <td>
                <% if (!u.is_admin) { %>
                  <% if (u.is_banned) { %>
                    <form method="post" action="/admin/users/<%= u.id %>/unban" class="inline-form">
                      <button type="submit" class="btn-sm btn-outline">Unban</button>
                    </form>
                  <% } else { %>
                    <form method="post" action="/admin/users/<%= u.id %>/ban" class="inline-form" onsubmit="return confirm('Ban <%= u.full_name %>? They won\'t be able to log in.')">
                      <button type="submit" class="btn-sm btn-danger">Ban</button>
                    </form>
                  <% } %>
                <% } else { %>
                  <span style="font-size:0.8rem;color:#aaa;">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Found Posts -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="package-open" class="inline-icon"></i> Found Board Posts</h3>
  <% if (foundPosts.length === 0) { %>
    <p class="muted">No found posts yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Posted by</th>
            <th>Status</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% foundPosts.forEach((p) => { %>
            <tr>
              <td><strong><%= p.item_name %></strong></td>
              <td style="font-size:0.85rem;color:#666;"><%= p.finder_name %></td>
              <td><span class="badge <%= p.status === 'unclaimed' ? 'badge-active' : p.status === 'claimed' ? 'badge-open' : 'badge-resolved' %>"><%= p.status %></span></td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;"><%= new Date(p.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %></td>
              <td>
                <form method="post" action="/admin/posts/<%= p.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this post permanently?')">
                  <button type="submit" class="btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Sighting Reports -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="eye" class="inline-icon"></i> Sighting Reports</h3>
  <% if (reports.length === 0) { %>
    <p class="muted">No reports yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Reporter</th>
            <th>Status</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% reports.forEach((r) => { %>
            <tr>
              <td><strong><%= r.item_name %></strong></td>
              <td style="font-size:0.85rem;color:#666;"><%= r.finder_name %> &lt;<%= r.finder_email %>&gt;</td>
              <td><span class="badge <%= r.status === 'open' ? 'badge-open' : 'badge-resolved' %>"><%= r.status %></span></td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;"><%= new Date(r.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %></td>
              <td>
                <form method="post" action="/admin/reports/<%= r.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this report and its messages?')">
                  <button type="submit" class="btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('_footer') %>
