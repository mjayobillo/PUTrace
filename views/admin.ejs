<%- include('_header') %>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
  <i data-lucide="shield" style="width:1.6rem;height:1.6rem;color:#3a56e4;"></i>
  <h2 style="font-size:1.6rem;margin:0;">Admin Panel</h2>
</div>

<!-- Stats bar -->
<div class="stats-bar" style="margin-bottom:1.5rem;">
  <div class="stat-card">
    <div class="stat-number"><%= users.length %></div>
    <div class="stat-label">Users</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= users.filter(u => u.is_banned).length %></div>
    <div class="stat-label">Banned</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= foundPosts.length %></div>
    <div class="stat-label">Found Posts</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= lostItems.length %></div>
    <div class="stat-label">Lost Items</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= reports.length %></div>
    <div class="stat-label">Reports</div>
  </div>
</div>

<!-- Users -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="users" class="inline-icon"></i> Users</h3>
  <% if (users.length === 0) { %>
    <p class="muted">No users yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Joined</th>
            <th>Role</th>
            <th class="admin-action-col">Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((u) => { %>
            <tr class="<%= u.is_banned ? 'admin-row-banned' : '' %>">
              <td><a href="/admin/users/<%= u.id %>" style="font-weight:600;color:#3a56e4;"><%= u.full_name %></a></td>
              <td style="font-size:0.85rem;color:#666;"><%= u.email %></td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;">
                <%= new Date(u.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric', year: 'numeric' }) %>,
                <%= new Date(u.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %>
              </td>
              <td>
                <% if (u.is_admin) { %>
                  <span class="badge badge-active">Admin</span>
                <% } else if (u.is_banned) { %>
                  <span class="badge badge-resolved" style="background:#fee2e2;color:#b91c1c;border-color:#fca5a5;">Banned</span>
                <% } else { %>
                  <span class="badge badge-none">User</span>
                <% } %>
              </td>
              <td>
                <% if (!u.is_admin) { %>
                  <% if (u.is_banned) { %>
                    <form method="post" action="/admin/users/<%= u.id %>/unban" class="inline-form">
                      <button type="submit" class="btn-sm btn-outline">Unban</button>
                    </form>
                  <% } else { %>
                    <form method="post" action="/admin/users/<%= u.id %>/ban" class="inline-form" onsubmit="return confirm('Ban <%= u.full_name %>? They won\'t be able to log in.')">
                      <button type="submit" class="btn-sm btn-danger">Ban</button>
                    </form>
                  <% } %>
                <% } else { %>
                  <span style="font-size:0.8rem;color:#aaa;">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Lost Items -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="search" class="inline-icon"></i> Lost Board Items</h3>
  <% if (lostItems.length === 0) { %>
    <p class="muted">No lost items right now.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Photo</th>
            <th>Item</th>
            <th>Category</th>
            <th>Owner</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% lostItems.forEach((item) => { %>
            <tr>
              <td style="width:56px;">
                <% if (item.image_url) { %>
                  <img src="<%= item.image_url %>" alt="<%= item.item_name %>" style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;cursor:pointer;" data-img="<%= item.image_url %>" data-label="<%= item.item_name %>" onclick="showAdminImg(this.dataset.img, this.dataset.label)" />
                <% } else { %>
                  <div style="width:48px;height:48px;background:#f0f2f5;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:1.2rem;">?</div>
                <% } %>
              </td>
              <td>
                <strong><%= item.item_name %></strong>
                <% if (item.item_description) { %><br><span style="font-size:0.8rem;color:#888;"><%= item.item_description.substring(0,60) %><%= item.item_description.length > 60 ? '…' : '' %></span><% } %>
              </td>
              <td style="font-size:0.85rem;color:#666;"><%= item.category || 'Other' %></td>
              <td style="font-size:0.85rem;color:#666;">
                <a href="/admin/users/<%= item.user_id %>" style="color:#3a56e4;font-weight:600;"><%= item.owner_name %></a>
              </td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;">
                <%= new Date(item.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %>,
                <%= new Date(item.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Found Posts -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="package-open" class="inline-icon"></i> Found Board Posts</h3>
  <% if (foundPosts.length === 0) { %>
    <p class="muted">No found posts yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Photo</th>
            <th>Item</th>
            <th>Posted by</th>
            <th>Status</th>
            <th class="type-col">Type</th>
            <th>Date</th>
            <th class="admin-action-col">Action</th>
          </tr>
        </thead>
        <tbody>
          <% foundPosts.forEach((p) => { %>
            <tr>
              <td style="width:56px;">
                <% if (p.image_url) { %>
                  <img src="<%= p.image_url %>" alt="<%= p.item_name %>" style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;cursor:pointer;" data-img="<%= p.image_url %>" data-label="<%= p.item_name %>" onclick="showAdminImg(this.dataset.img, this.dataset.label)" />
                <% } else { %>
                  <div style="width:48px;height:48px;background:#f0f2f5;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:1.2rem;">?</div>
                <% } %>
              </td>
              <td>
                <strong><%= p.item_name %></strong>
                <% if (p.item_description) { %><br><span style="font-size:0.8rem;color:#888;"><%= p.item_description.substring(0,60) %><%= p.item_description.length > 60 ? '…' : '' %></span><% } %>
                <% if (p.location_found) { %><br><span style="font-size:0.78rem;color:#aaa;"><i data-lucide="map-pin" style="width:0.7rem;height:0.7rem;display:inline;vertical-align:middle;"></i> <%= p.location_found %></span><% } %>
              </td>
              <td style="font-size:0.85rem;color:#666;"><%= p.finder_name %></td>
              <td><span class="badge <%= p.status === 'unclaimed' ? 'badge-active' : p.status === 'claimed' ? 'badge-open' : 'badge-resolved' %>"><%= p.status === 'claimed' ? 'claim pending' : p.status %></span></td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;">
                <%= new Date(p.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %>,
                <%= new Date(p.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %>
              </td>
              <td class="admin-actions">
                <a href="/admin/threads/post/<%= p.id %>" class="btn-sm btn-outline">View Thread</a>
                <form method="post" action="/admin/posts/<%= p.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this post permanently?')">
                  <button type="submit" class="btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Sighting Reports -->
<section class="card">
  <h3 style="margin-bottom:1rem;"><i data-lucide="eye" class="inline-icon"></i> Sighting Reports</h3>
  <% if (reports.length === 0) { %>
    <p class="muted">No reports yet.</p>
  <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Photo</th>
            <th>Item</th>
            <th>Reporter</th>
            <th>Status</th>
            <th>Type</th>
            <th>Date</th>
            <th class="admin-action-col">Action</th>
          </tr>
        </thead>
        <tbody>
          <% reports.forEach((r) => { %>
            <tr>
              <td>
                <% if (r.item_image) { %>
                  <img src="<%= r.item_image %>" alt="<%= r.item_name %>" style="width:48px;height:48px;object-fit:cover;border-radius:6px;cursor:pointer;" data-img="<%= r.item_image %>" data-label="<%= r.item_name %>" onclick="showAdminImg(this.dataset.img, this.dataset.label)" />
                <% } else { %>
                  <div style="width:48px;height:48px;background:#e2e8f0;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#ccc;">?</div>
                <% } %>
              </td>
              <td><strong><%= r.item_name %></strong></td>
              <td style="font-size:0.85rem;color:#666;"><%= r.finder_name %> &lt;<%= r.finder_email %>&gt;</td>
              <td><span class="badge <%= r.status === 'open' ? 'badge-open' : 'badge-resolved' %>"><%= r.status.charAt(0).toUpperCase() + r.status.slice(1) %></span></td>
              <td class="type-col">
                <% const isSighting = String(r.message || '').startsWith('[Sighting]'); %>
                <span class="badge badge-none"><%= isSighting ? 'Lost Sighting' : 'QR Scan' %></span>
              </td>
              <td style="font-size:0.82rem;color:#888;white-space:nowrap;">
                <%= new Date(r.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %>,
                <%= new Date(r.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %>
              </td>
              <td class="admin-actions">
                <a href="/admin/threads/report/<%= r.id %>" class="btn-sm btn-outline">View Thread</a>
                <form method="post" action="/admin/reports/<%= r.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this report and its messages?')">
                  <button type="submit" class="btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Image lightbox -->
<div id="adminImgModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:999;align-items:center;justify-content:center;" onclick="this.style.display='none'">
  <div style="max-width:90vw;max-height:90vh;text-align:center;">
    <img id="adminImgEl" src="" alt="" style="max-width:100%;max-height:80vh;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);" />
    <p id="adminImgLabel" style="color:#fff;margin-top:0.75rem;font-size:0.95rem;"></p>
  </div>
</div>
<script>
  function showAdminImg(src, label) {
    document.getElementById('adminImgEl').src = src;
    document.getElementById('adminImgLabel').textContent = label;
    document.getElementById('adminImgModal').style.display = 'flex';
  }
</script>

<%- include('_footer') %>
