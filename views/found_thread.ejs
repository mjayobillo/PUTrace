<%- include('_header') %>

<section class="card">
  <div class="section-head">
    <h2 class="section-title"><%= post.item_name %></h2>
    <a href="/messages" class="button btn-sm btn-outline">Back to Messages</a>
  </div>
  <p class="muted">Chat with: <strong><%= counterpartName %></strong></p>
  <p class="muted" style="font-size:0.85rem;">Confirm ownership and arrange pickup below.</p>
  <% if (isFinder && post.status === 'claimed' && post.claimer_user_id !== post.finder_user_id) { %>
    <form method="post" action="/found-messages/<%= post.id %>/unclaim" onsubmit="return confirm('Reject this claim? The post will become claimable again.')">
      <button type="submit" class="button btn-sm" style="background:#fee2e2;color:#b91c1c;border:1px solid #fca5a5;">Reject Claim</button>
    </form>
  <% } %>
</section>

<section class="card">
  <div class="chat-thread">
    <% if (!messages || messages.length === 0) { %>
      <p class="muted">No messages yet. Start the conversation below.</p>
    <% } else { %>
      <% messages.forEach((m) => { %>
        <div class="chat-bubble <%= m.is_me ? 'mine' : 'theirs' %>">
          <div class="chat-meta"><%= m.is_me ? 'You' : m.sender_name %></div>
          <div><%= m.message %></div>
          <div class="chat-time"><small><%= new Date(m.created_at).toLocaleString('en-US') %></small></div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <form method="post" action="/found-messages/<%= post.id %>">
    <label>Message
      <textarea name="message" rows="3" maxlength="1000" required placeholder="Type your message..."></textarea>
    </label>
    <button type="submit">Send Message</button>
  </form>
</section>

<script>
  (function () {
    var thread = document.querySelector('.chat-thread');
    if (thread) thread.scrollTop = thread.scrollHeight;
  })();
</script>

<%- include('_footer') %>
