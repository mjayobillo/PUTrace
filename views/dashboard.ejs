<%- include('_header') %>

<%
  const firstName = currentUser.full_name.split(' ')[0];
  const openReportsCount = reports.filter((r) => r.status === 'open').length;
  const resolvedReportsCount = reports.filter((r) => r.status === 'resolved').length;
  const totalActivity = reports.length + (foundActivity || []).length;
%>

<div class="dashboard-top">
  <h2 class="dashboard-title">Welcome, <%= firstName %></h2>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-number"><%= items.length %></div>
    <div class="stat-label">Items</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= openReportsCount %></div>
    <div class="stat-label">Open Reports</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= resolvedReportsCount %></div>
    <div class="stat-label">Resolved</div>
  </div>
</div>

<section class="card">
  <div class="section-head">
    <h2 class="section-title">Your Items</h2>
    <a href="/items/new" class="button btn-sm">Register New Item</a>
  </div>

  <form method="get" action="/dashboard" class="search-filters">
    <div class="row-filters">
      <label class="filter-search">
        Search
        <input type="text" name="search" value="<%= search %>" placeholder="Search items..." />
      </label>
      <label class="filter-category">
        Category
        <select name="category">
          <option value="">All</option>
          <% categories.forEach((cat) => { %>
            <option value="<%= cat %>" <%= filterCategory === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </label>
      <label class="filter-status">
        Status
        <select name="status">
          <option value="">All</option>
          <option value="active" <%= filterStatus === 'active' ? 'selected' : '' %>>Active</option>
          <option value="lost" <%= filterStatus === 'lost' ? 'selected' : '' %>>Lost</option>
          <option value="recovered" <%= filterStatus === 'recovered' ? 'selected' : '' %>>Recovered</option>
        </select>
      </label>
      <button type="submit" class="btn-sm">Filter</button>
      <% if (search || filterCategory || filterStatus) { %>
        <a href="/dashboard" class="button btn-sm btn-outline">Clear</a>
      <% } %>
    </div>
  </form>

  <% if (!items || items.length === 0) { %>
    <div class="center-text empty-state">
      <div class="empty-icon"><i data-lucide="package-search" style="width:3rem;height:3rem;color:#b8c1d8;"></i></div>
      <% if (search || filterCategory || filterStatus) { %>
        <p>No items match your filters. <a href="/dashboard">Clear filters</a></p>
      <% } else { %>
        <p>No items registered yet. Use "Register New Item" to add your first one.</p>
      <% } %>
    </div>
  <% } else { %>
    <div class="item-grid">
      <% items.forEach((item) => { %>
        <%- include('_dashboard_item_card', { item, baseUrl }) %>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="card">
  <h2>Activity</h2>
  <% if (totalActivity === 0) { %>
    <div class="center-text empty-state">
      <div class="empty-icon"><i data-lucide="inbox" style="width:3rem;height:3rem;color:#b8c1d8;"></i></div>
      <p>No activity yet. When someone scans your QR code or you claim a found item, it will appear here.</p>
    </div>
  <% } else { %>
    <%
      const allActivity = [
        ...reports.map(r => ({ ...r, _type: 'report' })),
        ...(foundActivity || []).map(fp => ({ ...fp, _type: 'found' }))
      ].sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
    %>
    <div class="report-card-list">
      <% allActivity.forEach((item) => { %>
        <% if (item._type === 'report') { %>
          <%- include('_dashboard_report_row', { r: item }) %>
        <% } else { %>
          <%
            const fpDate = new Date(item.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' });
            const fpTime = new Date(item.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' });
          %>
          <div class="report-card">
            <div class="report-card-header">
              <strong class="report-item-name"><%= item.item_name %></strong>
              <span class="badge badge-active">Found Board</span>
            </div>
            <div class="report-card-body">
              <p class="report-finder"><span class="report-label"><%= item.role === 'claimer' ? 'You claimed' : 'Claimed by' %>:</span> <%= item.other_name %></p>
              <p style="font-size:0.78rem;color:#bbb;margin-top:0.4rem;"><%= fpDate %>, <%= fpTime %></p>
            </div>
            <div class="report-card-actions">
              <a href="/found-messages/<%= item.id %>" class="button btn-sm btn-outline">Open Chat</a>
            </div>
          </div>
        <% } %>
      <% }) %>
    </div>
  <% } %>
</section>

<div id="delete-confirm-modal" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="delete-confirm-title">
  <div class="modal-box modal-box-error">
    <button type="button" class="modal-close" id="delete-confirm-close" aria-label="Close delete confirmation">&times;</button>
    <div style="text-align:center;margin-bottom:0.8rem;"><i data-lucide="trash-2" style="width:2.2rem;height:2.2rem;color:#e74c3c;"></i></div>
    <h3 id="delete-confirm-title" class="error-title">Delete item?</h3>
    <p id="delete-confirm-message" class="error-message">This action cannot be undone.</p>
    <div class="success-actions">
      <button type="button" class="btn-sm btn-outline" id="delete-confirm-cancel">Cancel</button>
      <button type="button" class="btn-sm btn-danger" id="delete-confirm-submit">Delete</button>
    </div>
  </div>
</div>

<script>
  (function () {
    var modal = document.getElementById('delete-confirm-modal');
    var titleEl = document.getElementById('delete-confirm-title');
    var messageEl = document.getElementById('delete-confirm-message');
    var closeBtn = document.getElementById('delete-confirm-close');
    var cancelBtn = document.getElementById('delete-confirm-cancel');
    var submitBtn = document.getElementById('delete-confirm-submit');
    var pendingForm = null;

    if (!modal || !titleEl || !messageEl || !submitBtn) return;

    function closeModal() {
      modal.style.display = 'none';
      pendingForm = null;
    }

    document.querySelectorAll('.delete-confirm-form').forEach(function (form) {
      form.addEventListener('submit', function (event) {
        event.preventDefault();
        pendingForm = form;
        var label = form.dataset.deleteLabel || 'this item';
        var message = form.dataset.deleteMessage || 'Delete this item?';
        titleEl.textContent = 'Delete "' + label + '"?';
        messageEl.textContent = message;
        modal.style.display = 'flex';
        submitBtn.focus();
      });
    });

    submitBtn.addEventListener('click', function () {
      if (!pendingForm) return;
      modal.style.display = 'none';
      pendingForm.submit();
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function (event) {
      if (event.target === modal) closeModal();
    });
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeModal();
    });
  })();
</script>
<%- include('_footer') %>
