<%- include('_header') %>

<section class="card">
  <h2>Your Conversations</h2>

  <% if (!conversations || conversations.length === 0) { %>
    <div class="center-text empty-state">
      <div class="empty-icon">...</div>
      <p>No conversations yet.</p>
    </div>
  <% } else { %>
    <div class="conversation-list">
      <% conversations.forEach((c) => { %>
        <a href="<%= c.url %>" class="conversation-card">
          <div class="conversation-head">
            <strong><%= c.item_name %></strong>
            <span class="badge <%= c.status === 'open' ? 'badge-open' : c.status === 'claimed' ? 'badge-active' : 'badge-resolved' %>">
              <%= c.status === 'open' ? 'Open' : c.status === 'claimed' ? 'Claimed' : 'Resolved' %>
            </span>
          </div>
          <p class="muted">With: <%= c.counterpart_name %></p>
          <p class="conversation-preview"><%= (c.preview || '').replace(/^\[Sighting\]\s*/, '') %></p>
          <p class="muted"><small><%= new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>, <%= new Date(c.created_at).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></small></p>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('_footer') %>
