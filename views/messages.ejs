<%- include('_header') %>

<section class="card">
  <h2>Your Conversations</h2>

  <% if (!conversations || conversations.length === 0) { %>
    <div class="center-text empty-state">
      <div class="empty-icon">...</div>
      <p>No conversations yet.</p>
    </div>
  <% } else { %>
    <div class="conversation-list">
      <% conversations.forEach((c) => { %>
        <a href="<%= c.url %>" class="conversation-card">
          <div class="conversation-head">
            <strong><%= c.item_name %></strong>
            <div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">
              <span class="badge <%= c.kind === 'found' ? 'badge-active' : 'badge-open' %>" style="font-size:0.68rem;opacity:0.85;"><%= c.kind === 'found' ? 'Found Board' : 'Lost Report' %></span>
              <span class="badge <%= c.status === 'open' ? 'badge-open' : c.status === 'claimed' ? 'badge-active' : 'badge-resolved' %>">
                <%= c.status === 'open' ? 'Open' : c.status === 'claimed' ? 'Claimed' : c.status === 'returned' ? 'Returned' : 'Resolved' %>
              </span>
            </div>
          </div>
          <p class="muted">With: <%= c.counterpart_name %></p>
          <p class="conversation-preview"><%= (c.preview || '').replace(/^\[Sighting\]\s*/, '') %></p>
          <p class="muted"><small><%= new Date(c.created_at).toLocaleDateString('en-US', { timeZone: 'Asia/Manila', month: 'short', day: 'numeric' }) %>, <%= new Date(c.created_at).toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour: 'numeric', minute: '2-digit' }) %></small></p>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('_footer') %>
